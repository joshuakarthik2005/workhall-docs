# ============================================================
# Workhall Docs — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# Groq API Key (for chat/answer generation with Mixtral)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Supabase Project URL
# Found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (NOT the anon/public key!)
# Found in: Supabase Dashboard → Settings → API → Service Role Key
# This key bypasses Row Level Security — keep it secret!
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Base URL of your Docusaurus docs site (for generating source links)
DOCS_BASE_URL=http://localhost:3000
